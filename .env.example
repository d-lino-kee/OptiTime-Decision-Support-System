NODE_ENV=development
PORT=3001

# Mongo (set DB name independently if you want a non-default DB)
MONGODB_URI=mongodb://localhost:27017/optitime
MONGODB_DB=optitime

# Redis / BullMQ
REDIS_URL=redis://localhost:6379

# AI sidecar (FastAPI). Must match apps/ai-service/.env value.
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_HMAC_SECRET=dev_ai_hmac_change_me

# Weaviate (only used in real-model mode; safe to leave default for dev)
WEAVIATE_URL=http://localhost:8080
# WEAVIATE_API_KEY=

# Firebase Admin — project id only; Application Default Credentials
# (`gcloud auth application-default login` or a service-account JSON via
# GOOGLE_APPLICATION_CREDENTIALS) provide the actual auth.
FIREBASE_PROJECT_ID=replace-with-your-firebase-project-id
